@*
    @model tells Razor what type of data this view expects.
    IEnumerable<Book> means "a collection of Book objects" - like a list.
    The controller sends this via: return View(books);
*@
@model IEnumerable<CetStudentBook.Models.Book>

@{
    ViewData["Title"] = "Books";
    @* ViewData is a dictionary you can use to pass small pieces of info
       from controller to view (or set inside a view like here).
       The _Layout.cshtml uses ViewData["Title"] in the <title> tag. *@
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Books</h1>
    @* asp-action="Create" generates: href="/Books/Create"
       ASP.NET Tag Helpers (asp-*) are like smart HTML attributes — they generate
       correct URLs based on your controller/action names. *@
    <a asp-action="Create" class="btn btn-success">+ Add New Book</a>
</div>

@if (!Model.Any())
{
    @* Model is the IEnumerable<Book> the controller passed in.
       .Any() returns true if there's at least one item. *@
    <div class="alert alert-info">
        No books yet. <a asp-action="Create">Add the first one!</a>
    </div>
}
else
{
    <table class="table table-hover table-bordered">
        <thead class="table-dark">
            <tr>
                <th>Name</th>
                <th>Author</th>
                <th>Publish Date</th>
                <th>Page Count</th>
                <th>Price</th>
                <th>Category</th>
                <th>Second Hand?</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @* @foreach iterates over every Book in the Model collection.
               Each iteration gives us one book object. *@
            @foreach (var book in Model)
            {
                <tr>
                    <td>@book.Name</td>
                    <td>@book.Author</td>
                    @* .ToString("dd MMM yyyy") formats the date as "01 Jan 2020" *@
                    <td>@book.PublishDate.ToString("dd MMM yyyy")</td>
                    <td>@book.PageCount</td>
                    <td>@book.Price.ToString("C")</td>
                    <td>@(book.Category?.Name ?? "-")</td>
                    <td>
                        @(book.IsSecondHand ? "Yes" : "No")
                    </td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@book.Id" class="btn btn-sm btn-warning">Edit</a>
                        <a asp-action="Delete" asp-route-id="@book.Id" class="btn btn-sm btn-danger">Delete</a>
                        <form asp-controller="Cart" asp-action="Add" method="post" style="display:inline">
                            <input type="hidden" name="bookId" value="@book.Id" />
                            <button type="submit" class="btn btn-sm btn-primary">Add to Cart</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
